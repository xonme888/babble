# ===========================================
# 환경 변수 설정 파일
# ===========================================
# 이 파일을 .env로 복사한 후 실제 값으로 변경하세요.
# 명령어: cp .env.example .env
#
# ⚠️ 주의: .env 파일은 절대 Git에 커밋하지 마세요!
# ===========================================

# ===========================================
# 실행 환경
# ===========================================
# development, production, test
NODE_ENV=development

# 서버 포트
PORT=3000

# ===========================================
# 데이터베이스 설정 (PostgreSQL)
# ===========================================
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USERNAME=your_username
DATABASE_PASSWORD=your_password
DATABASE_DATABASE=babble
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# 커넥션 풀 설정
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=20

# 느린 쿼리 자동 로깅 threshold (ms) — 0이면 비활성화, 프로덕션 권장: 1000
# DATABASE_MAX_QUERY_EXECUTION_TIME=0

# ===========================================
# JWT 토큰 설정
# ===========================================
# ⚠️ CRITICAL: JWT_SECRET은 반드시 강력한 랜덤 값으로 설정하세요!
# 생성 방법: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_MINIMUM_32_CHARACTERS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===========================================
# 이메일 설정
# ===========================================
# Mail Provider: sendgrid, google, console
MAIL_PROVIDER=console

# SendGrid 설정
# SendGrid API 키: https://sendgrid.com/ 에서 발급
SENDGRID_APIKEY=
SENDGRID_FROMEMAIL=noreply@yourapp.com

# Google Mail 설정 (앱 비밀번호 사용)
# https://myaccount.google.com/apppasswords 에서 발급
GOOGLE_MAIL_USER=
GOOGLE_MAIL_PASSWORD=

# ===========================================
# Redis 설정
# ===========================================
# Redis를 사용하지 않으면 자동으로 DB fallback 동작

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# 큐 암호화 설정
# ===========================================
# 큐 데이터(이메일 본문 등) 암호화 전용 키 — JWT_SECRET과 반드시 다른 값 사용
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QUEUE_ENCRYPTION_KEY=

# ===========================================
# CORS 설정
# ===========================================
# 허용할 Origin을 쉼표로 구분하여 입력
# 예: https://yourapp.com,https://www.yourapp.com

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# AI 서비스 설정 — Redis 큐로 통신 (HTTP URL 불필요)
# ===========================================
# AI_SERVICE_TIMEOUT_MS=60000  # 분석 결과 폴링 타임아웃 (기본 60초)

# ===========================================
# 로깅 설정
# ===========================================
# LOG_FORMAT: json 또는 text
# DEBUG: true 또는 false (운영에서는 false 권장)

# 개발: text + DEBUG=true / 프로덕션: json + DEBUG=false
LOG_FORMAT=json
DEBUG=true

# ===========================================
# 프로덕션 권장 설정 (참고용)
# ===========================================
# NODE_ENV=production
# DATABASE_SYNCHRONIZE=false
# DATABASE_LOGGING=false
# DATABASE_MAX_QUERY_EXECUTION_TIME=1000
# LOG_FORMAT=json
# DEBUG=false
