{
  "name": "app-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node -r tsconfig-paths/register build/index.js",
    "build": "tsc -p tsconfig.build.json",
    "dev": "ts-node --transpile-only -r tsconfig-paths/register src/index.ts",
    "test": "npm run test:unit && npm run test:int && npm run test:e2e",
    "test:unit": "node -r ./test/utils/preload.js ./node_modules/.bin/jest --selectProjects unit --forceExit",
    "test:int": "node -r ./test/utils/preload.js ./node_modules/.bin/jest --selectProjects integration --maxWorkers=1 --forceExit",
    "test:e2e": "node -r ./test/utils/preload.js ./node_modules/.bin/jest --selectProjects e2e --maxWorkers=1 --forceExit",
    "test:coverage": "node -r ./test/utils/preload.js ./node_modules/.bin/jest --coverage --forceExit",
    "migration:generate": "TS_NODE_PROJECT=tsconfig.json node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -o src/shared/infra/persistence/migrations/migration -d src/shared/infra/persistence/data-source.ts",
    "migration:run": "TS_NODE_PROJECT=tsconfig.json node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/shared/infra/persistence/data-source.ts",
    "migration:revert": "TS_NODE_PROJECT=tsconfig.json node -r ts-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/shared/infra/persistence/data-source.ts",
    "seed:scripts": "ts-node -r tsconfig-paths/register src/scripts/seed-scripts.ts",
    "seed:badges": "ts-node -r tsconfig-paths/register src/scripts/seed-badges.ts",
    "seed:game-configs": "ts-node -r tsconfig-paths/register src/scripts/seed-game-configs.ts",
    "worker:email": "ts-node -T -r tsconfig-paths/register src/worker.ts",
    "worker:email:prod": "node -r tsconfig-paths/register build/worker.js",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "openapi:generate": "ts-node -r tsconfig-paths/register src/scripts/generate-openapi-spec.ts",
    "openapi:validate": "npx @redocly/cli lint openapi.json --config .redocly.yaml",
    "validate:contract": "ts-node -r tsconfig-paths/register src/scripts/validate-contract.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "commonjs",
  "dependencies": {
    "@bull-board/api": "^6.17.0",
    "@bull-board/express": "^6.17.0",
    "@bull-board/ui": "^6.17.0",
    "@sendgrid/mail": "^8.1.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "he": "^1.2.0",
    "helmet": "^8.1.0",
    "i18next": "^25.8.0",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.9.2",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pg": "^8.17.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "tsyringe": "^4.10.0",
    "typeorm": "^0.3.28",
    "typeorm-transactional": "^0.5.0"
  },
  "devDependencies": {
    "@redocly/cli": "^2.18.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/he": "^1.2.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.10",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "jest-openapi": "^0.14.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
